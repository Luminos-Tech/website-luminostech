# .htaccess - chỉ dùng khi deploy trên Apache
# Nếu dùng Docker (Flask server), .htaccess không cần thiết

# Disable directory listing
Options -Indexes

# Prevent access to hidden files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to .html files
<FilesMatch "\.html$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to .env
<FilesMatch "^\.env$">
    Order allow,deny
    Deny from all
</FilesMatch>
